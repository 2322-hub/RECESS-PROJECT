# Required
SECRET_KEY=change-me-to-a-random-secret-key
ADMIN_PASSWORD=change-me-to-a-secure-password

# Flask
FLASK_DEBUG=false
PORT=5000

# Database
DATABASE_URL=sqlite:///bi_platform_demo.db
DB_POOL_SIZE=5

# Auth
ADMIN_USERNAME=admin

# Security
SQL_READ_ONLY=true
CORS_ORIGINS=*

# Rate Limiting (switch to redis:// for production)
RATELIMIT_DEFAULT=60/minute
RATELIMIT_STORAGE_URI=memory://

# Redis (optional — required for Redis rate limit backend)
REDIS_URL=redis://redis:6379/0

# Sentry (optional — set DSN for error tracking)
SENTRY_DSN=

# Logging
LOG_FORMAT=json
LOG_LEVEL=INFO

# SQLAlchemy Connection Pooling
DB_POOL_SIZE=5
DB_POOL_MAX_OVERFLOW=10
